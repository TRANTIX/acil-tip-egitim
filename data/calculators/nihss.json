  "interpretation": [
    { "min": 0, "max": 0, "label": "Nörolojik Defisit Yok", "color": "green", "description": "Semptomlar olabilir ama muayene normaldir." },
    { "min": 1, "max": 4, "label": "Hafif", "color": "green", "description": "Hafif defisit. tPA uygunluğu değerlendir." },
    { "min": 5, "max": 15, "label": "Orta", "color": "yellow", "description": "Orta defisit. tPA endikasyonu değerlendir (≤4.5 saat)." },
    { "min": 16, "max": 20, "label": "Orta-Ağır", "color": "orange", "description": "Orta-ağır defisit. tPA + trombektomi değerlendir." },
    { "min": 21, "max": 42, "label": "Ağır", "color": "red", "description": "Ağır defisit. Trombektomi, nörolog ve nöroradyoloji acil." }
  ],
  "clinicalNote": "tPA için: NIHSS 4-25, semptom başlangıcından ≤4.5 saat, kontrendikasyon yok. Büyük damar tıkanıklığında NIHSS ≥6 + görüntüleme ile trombektomi değerlendir.",
  "source": "Brott T, et al. Measurements of acute cerebral infarction: a clinical examination scale. Stroke. 1989;20(7):864-870.",
  "disclaimer": "Bu hesaplayıcı eğitim amaçlıdır. NIHSS sertifikalı uzman tarafından uygulanmalıdır. Klinik kararlar hasta değerlendirmesi ile verilmelidir."
